{
  "name": "sabo-lang",
  "displayName": "Sabo Language",
  "description": "Syntax highlighting for the Sabo programming language",
  "version": "0.1.0",
  "publisher": "sabo-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "sabo",
        "aliases": ["Sabo", "sabo"],
        "extensions": [".sabo"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sabo",
        "scopeName": "source.sabo",
        "path": "./syntaxes/sabo.tmLanguage.json"
      }
    ]
  }
}
