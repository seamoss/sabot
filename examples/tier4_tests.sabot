-- =============================================
-- Sabo Tier 4: Test Framework
-- =============================================

-- 1. Basic assertions
2 3 + 5 assert_eq
true assert
1 2 assert_neq
"Assertions: OK" println

-- 2. Type introspection
42 type_of "int" assert_eq
3.14 type_of "float" assert_eq
"hi" type_of "string" assert_eq
:ok type_of "symbol" assert_eq
true type_of "bool" assert_eq
{1, 2} type_of "list" assert_eq
#{} type_of "map" assert_eq
[1 +] type_of "quotation" assert_eq
"Type checks: OK" println

-- 3. String utilities
"hello world" " " split {"hello", "world"} assert_eq
{"a", "b", "c"} ", " join "a, b, c" assert_eq
"  spaces  " trim "spaces" assert_eq
"hello world" "world" contains assert
{1, 2, 3} 2 contains assert
"String utils: OK" println

-- 4. Conversions
"42" to_int 42 assert_eq
"3.14" to_float 3.14 assert_eq
3.7 to_int 3 assert_eq
42 to_float 42.0 assert_eq
"Conversions: OK" println

-- 5. Error handling with assertions
let result = [false assert] try
result type_of "list" assert_eq
"Error handling: OK" println

-- 6. Word definitions + test
: double
  [n] -> n 2 *
;

5 double 10 assert_eq
0 double 0 assert_eq
-3 double -6 assert_eq
"Word tests: OK" println

-- 7. Pattern matching test
: fib
  [0] -> 0
  [1] -> 1
  [n] -> n 1 - fib n 2 - fib +
;

10 fib 55 assert_eq
0 fib 0 assert_eq
1 fib 1 assert_eq
"Fibonacci tests: OK" println

-- 8. Higher-order functions
{1, 2, 3, 4, 5} [2 *] map {2, 4, 6, 8, 10} assert_eq
{1, 2, 3, 4, 5} [2 >] filter {3, 4, 5} assert_eq
{1, 2, 3, 4, 5} 0 [+] fold 15 assert_eq
"Higher-order tests: OK" println

"" println
"All tests passed!" println
