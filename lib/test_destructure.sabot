-- Destructuring let tests

-- List destructuring
let {a, b, c} = {10, 20, 30}
a 10 assert_eq
b 20 assert_eq
c 30 assert_eq

-- Head/tail destructuring
let {h | t} = {1, 2, 3, 4}
h 1 assert_eq
t {2, 3, 4} assert_eq

-- Map destructuring
let #{"name" => name, "age" => age} = #{"name" => "Alice", "age" => 30}
name "Alice" assert_eq
age 30 assert_eq

-- Destructure from expression result
let {x, y} = {100, 200}
x 100 assert_eq
y 200 assert_eq

-- Single element list
let {only} = {42}
only 42 assert_eq

-- Head/tail of two elements
let {first | rest} = {99, 100}
first 99 assert_eq
rest {100} assert_eq

-- Map with single key
let #{"x" => val} = #{"x" => 7, "y" => 8}
val 7 assert_eq

"Destructuring tests passed!" println
