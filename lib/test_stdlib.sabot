-- Standard Library Tests
-- Run with: sabo test lib/test_stdlib.sabo

-- ===== Math =====
"lib/math.sabot" import

5 square 25 assert_eq
3 cube 27 assert_eq
-7 abs 7 assert_eq
0 abs 0 assert_eq
5 negate -5 assert_eq
-3 negate 3 assert_eq

5 sign 1 assert_eq
-5 sign -1 assert_eq
0 sign 0 assert_eq

3 7 min 3 assert_eq
3 7 max 7 assert_eq
5 1 10 clamp 5 assert_eq
-5 1 10 clamp 1 assert_eq
15 1 10 clamp 10 assert_eq

2 8 pow 256 assert_eq
2 0 pow 1 assert_eq
3 3 pow 27 assert_eq

12 8 gcd 4 assert_eq
4 6 lcm 12 assert_eq

{1, 2, 3, 4, 5} sum 15 assert_eq
{1, 2, 3, 4} product 24 assert_eq
{2, 4, 6} average 4 assert_eq

5 factorial 120 assert_eq
0 factorial 1 assert_eq

0 fib 0 assert_eq
1 fib 1 assert_eq
6 fib 8 assert_eq

4 even? true assert_eq
5 even? false assert_eq
5 odd? true assert_eq
6 odd? false assert_eq

10 5 divisible? true assert_eq
10 3 divisible? false assert_eq

"Math tests passed!" println

-- ===== List =====
"lib/list.sabot" import

{1, 2, 3, 4, 5} 3 take {1, 2, 3} assert_eq
{1, 2, 3, 4, 5} 2 drop_n {3, 4, 5} assert_eq
{1, 2, 3} 0 take {} assert_eq
{} 5 take {} assert_eq

{{1, 2}, {3, 4}, {5}} flatten {1, 2, 3, 4, 5} assert_eq

{1, 2, 3} {4, 5, 6} zip {{1, 4}, {2, 5}, {3, 6}} assert_eq

{1, 2, 3, 4} [2 >] any? true assert_eq
{1, 2, 3} [10 >] any? false assert_eq
{2, 4, 6} [even?] all? true assert_eq
{2, 3, 6} [even?] all? false assert_eq

{1, 2, 3, 2, 1} unique {1, 2, 3} assert_eq

{1, 2, 3} last 3 assert_eq
{1, 2, 3} init {1, 2} assert_eq

"x" 3 repeat {"x", "x", "x"} assert_eq

{10, 20, 30} 20 index_of 1 assert_eq
{10, 20, 30} 99 index_of -1 assert_eq

"List tests passed!" println

-- ===== String =====
"lib/string.sabot" import

"ab" 3 str_repeat "ababab" assert_eq
"ab" 0 str_repeat "" assert_eq

"42" 5 "0" pad_left "00042" assert_eq
"hi" 5 " " pad_right "hi   " assert_eq

"hello world" split_words {"hello", "world"} assert_eq
"a\nb\nc" lines {"a", "b", "c"} assert_eq
{"hello", "world"} join_words "hello world" assert_eq
{"a", "b"} unlines "a\nb" assert_eq

"" empty? true assert_eq
"x" empty? false assert_eq
"   " blank? true assert_eq
"  x " blank? false assert_eq

"hi" "*" surround "*hi*" assert_eq
"hi" quote "\"hi\"" assert_eq
"hi" parens "(hi)" assert_eq

"String tests passed!" println

-- ===== Functional =====
"lib/functional.sabot" import

5 identity 5 assert_eq
5 10 const 5 assert_eq

10 3 [swap -] flip 7 assert_eq

-- pipe through multiple transformations
5 {[2 *], [1 +], [to_str]} pipe "11" assert_eq

"Functional tests passed!" println

-- ===== Map =====
"lib/map.sabot" import

#{} empty_map? true assert_eq
#{"a" => 1} empty_map? false assert_eq
#{"a" => 1, "b" => 2} map_size 2 assert_eq

"Map tests passed!" println

"All stdlib tests passed!" println
